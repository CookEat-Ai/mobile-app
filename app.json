{
  "expo": {
    "name": "CookEat",
    "slug": "cookeat",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cookeat",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "appStoreUrl": "https://apps.apple.com/fr/app/cookeat-ai/id6748924011",
      "supportsTablet": true,
      "bundleIdentifier": "com.gokugen.cookeat",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "CookEat AI souhaite accéder à votre bibliothèque photo pour reconnaitre les ingrédients que vous nous affichez.",
        "NSMicrophoneUsageDescription": "Cette application utilise le microphone pour la reconnaissance vocale afin de comprendre vos ingrédients disponibles.",
        "NSSpeechRecognitionUsageDescription": "CookEat utilise la reconnaissance vocale pour comprendre vos ingrédients et vous proposer des recettes adaptées à ce que vous avez chez vous.",
        "NSUserNotificationsUsageDescription": "CookEat AI souhaite vous envoyer des notifications pour vous rappeler de cuisiner, vous proposer de nouvelles recettes adaptées à vos goûts et vous tenir informé de vos recettes favorites. Ces rappels vous aident à rester motivé et à découvrir de nouvelles saveurs culinaires."
      }
    },
    "android": {
      "playStoreUrl": "",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "com.android.vending.BILLING",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ],
      "package": "com.gokugen.cookeat"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withGradleProperties",
      "expo-router",
      "@react-native-voice/voice",
      [
        "expo-notifications",
        {
          "color": "#FEB50A",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashscreen-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FEB50A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "014735a5-662a-4ab0-84a8-d1e8653c94d6"
      },
      "apiBaseUrl": "http://192.168.1.192:8083/api"
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/014735a5-662a-4ab0-84a8-d1e8653c94d6"
    }
  }
}