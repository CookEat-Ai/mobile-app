{
  "expo": {
    "name": "CookEat Ai",
    "slug": "cookeat",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cookeat",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "appStoreUrl": "https://apps.apple.com/fr/app/cookeat-ai/id6748924011",
      "supportsTablet": true,
      "bundleIdentifier": "com.gokugen.cookeat",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "CookEat AI would like to access your photo library to recognize the ingredients you show us.",
        "NSMicrophoneUsageDescription": "This app uses the microphone for voice recognition to understand your available ingredients.",
        "NSSpeechRecognitionUsageDescription": "CookEat uses voice recognition to understand your ingredients and suggest recipes tailored to what you have at home.",
        "NSUserNotificationsUsageDescription": "Recevez des rappels et des suggestions de recettes personnalisées.",
        "NSUserTrackingUsageDescription": "Your data allows us to offer you recipes and advertisements that truly match your tastes."
      },
      "appleTeamId": "P48MLLHB99"
    },
    "locales": {
      "fr": "./locales/ios/fr.json",
      "en": "./locales/ios/en.json"
    },
    "android": {
      "playStoreUrl": "",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "com.android.vending.BILLING",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ],
      "package": "com.gokugen.cookeat",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ],
      "./plugins/withGradleProperties",
      "./plugins/withManifestFix",
      "./plugins/withSentryXcodeEnv",
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/CronosPro.otf",
            "./assets/fonts/CronosProBold.otf",
            "./assets/fonts/Degular.otf",
            "./assets/fonts/Degular Semibold.otf"
          ]
        }
      ],
      [
        "react-native-appsflyer",
        {
          "shouldUseStrictMode": false,
          "shouldUsePurchaseConnector": true,
          "preferAppsFlyerBackupRules": false
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "cookeat",
          "organization": "hadjadji-mohamed"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "CookEat AI would like to access your camera to take photos of your ingredients."
        }
      ],
      "@react-native-voice/voice",
      [
        "expo-notifications",
        {
          "color": "#FDF9E2",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mascot.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#FDF9E2"
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": [
            "text/*"
          ],
          "androidMultiIntentFilters": []
        }
      ],
      "expo-image",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "014735a5-662a-4ab0-84a8-d1e8653c94d6"
      },
      "apiBaseUrl": "http://192.168.1.124:8083/api"
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/014735a5-662a-4ab0-84a8-d1e8653c94d6"
    }
  }
}
